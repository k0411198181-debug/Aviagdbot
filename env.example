# ── Обязательно ──────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather
TP_TOKEN=your_travelpayouts_api_token
TP_MARKER=your_travelpayouts_marker

# ── Настройки бота ────────────────────────────────────────────────────────
BOT_USERNAME=ticketradaRubot
DB_PATH=bot.db
CHECK_INTERVAL=3600        # Интервал проверки алертов в секундах (1 час)
